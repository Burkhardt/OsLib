@startuml OsLib-Os-ClassDiagram
title OsLib Os Class Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam linetype ortho
skinparam DiagramFontName "Casual"
skinparam DiagramFontSize 36
skinparam ClassFontName "Casual"
skinparam ClassFontSize 36
skinparam ClassAttributeIconSize 10
skinparam ClassAttributeFontName Casual
skinparam ClassAttributeFontColor #053583
skinparam ClassAttributeFontWeight normal
skinparam ClassAttributeFontSize 12
skinparam ClassMethodFontName "Casual"
skinparam ClassMethodFontSize 12
skinparam ClassMethodFontWeight 500
skinparam ClassFontName "Casual"
skinparam ClassAttributeFontStyle normal
skinparam ClassBorderColor #0f766e
skinparam ClassBackgroundColor #ccfbf1
skinparam ClassFontColor #111827
skinparam EnumBorderColor #b45309
skinparam EnumBackgroundColor #fef3c7
skinparam EnumFontColor #7c2d12
skinparam NoteBackgroundColor #fff7d6
skinparam NoteBorderColor #d4b106

show circle

together {
	enum OsType << (E,#f59e0b) >> {
		Windows
		MacOS
		Ubuntu
	}
		enum CloudRootResolutionMode << (E,#f59e0b) >> {
			ConfiguredAndProbed
			ConfiguredOnly
		}
	enum CloudStorageType << (E,#f59e0b) >> {
		Dropbox
		OneDrive
		GoogleDrive
	}
	class "Legend<size:10>ⓈⒶⓅ</size>" as LegendSample {
		+{static} staticMethod() : void
		-{static} staticProperty : string
		==
		~<i>Note on class markers :</i>
		<size:10>Ⓢ</size>tatic
		<size:10>Ⓐ</size>bstract
		Ⓟartial
		--
		- privateField : string
		+ publicField : string
		# protectedField : string
		~ internalField : string
		--
		- privateMethod() : void
		+ publicMethod() : void
		# protectedMethod() : void
		~ internalMethod() : void
	}
}

abstract class "<size:18>ConfigFile</size>Ⓐ<TData>" as ConfigFile << (C,#14b8a6) >> {
	+ Data : TData
	--
	+ Load() : TData
	# CreateDefaultData() : TData
	# NormalizeData(data : TData) : TData
	+ Save() : void
	~ SetFullName(fullName : string) : bool
}

class "<size:18>CloudModel</size>" as CloudModel << (C,#14b8a6) >> {
	+ DropboxRoot : RaiPath
	+ OneDriveRoot : RaiPath
	+ GoogleDriveRoot : RaiPath
	+ Roots : IReadOnlyDictionary<CloudStorageType, RaiPath>
	--
	+ GetRoot(provider : CloudStorageType) : RaiPath
	~ SetRoot(provider : CloudStorageType, value : string) : void
	~ MergeMissingDiscoveredRoots(discoveredRoots : IReadOnlyDictionary<CloudStorageType, string>) : bool
	~ Clone() : CloudModel
	~ Normalize() : void
}

class "<size:18>OsConfigModel</size>" as OsConfigModel << (C,#14b8a6) >> {
	+ HomeDir : RaiPath
	+ TempDir : RaiPath
	+ LocalBackupDir : RaiPath
	+ DefaultCloudOrder : List<CloudStorageType>
	+ Cloud : CloudModel
	+ DropboxPath : RaiPath
	+ OneDrivePath : RaiPath
	+ GooglePath : RaiPath
	+ CloudDirPaths : IReadOnlyDictionary<CloudStorageType, RaiPath>
	--
	+ GetCloudDirPath(provider : CloudStorageType) : RaiPath
	~ Clone() : OsConfigModel
	~ Normalize() : void
}

class "<size:18>OsConfigFile</size>" as OsConfigFile << (C,#14b8a6) >> {
	--
	# CreateDefaultData() : OsConfigModel
	# NormalizeData(data : OsConfigModel) : OsConfigModel
}

