@startuml OsLib-RaiFile-Hierarchy
' Release: 3.7.3

skinparam backgroundColor white
skinparam shadowing false
skinparam DiagramFontName "Casual"
skinparam DiagramFontSize 36
skinparam ClassFontName "Casual"
skinparam ClassFontSize 28
skinparam ClassAttributeIconSize 10
skinparam ClassAttributeFontName Casual
skinparam ClassAttributeFontColor #053583
skinparam ClassAttributeFontWeight normal
skinparam ClassAttributeFontSize 12
skinparam ClassMethodFontName "Casual"
skinparam ClassMethodFontSize 12
skinparam ClassMethodFontWeight 500
skinparam ClassAttributeFontStyle normal
skinparam ClassBorderColor #0f766e
skinparam ClassBackgroundColor #ccfbf1
skinparam ClassFontColor #111827
skinparam EnumBorderColor #b45309
skinparam EnumBackgroundColor #fef3c7
skinparam EnumFontColor #7c2d12
skinparam NoteBackgroundColor #fff7d6
skinparam NoteBorderColor #d4b106
skinparam ArrowColor #9b2c2c
skinparam ArrowFontColor #374151
skinparam ArrowFontName "Casual"
show fields
show methods

title OsLib RaiFile Hierarchy

interface IPathConvention {
  +Convention : PathConventionType
  +ApplyPathConvention()
}

enum PathConventionType {
  CanonicalByName
  ItemIdTree3x3
  ItemIdTree8x2
}

class RaiPath {
  +Path : string
  +operator /(self : RaiPath, subDir : string) : RaiPath
}

class "CanonicalPath\n<<deprecated>>" as CanonicalPath {
  +RootPath : string
  +FileStem : string
  +Apply()
}

class ItemTreePath {
  +RootPath : string
  +ItemId : string
  +Topdir : string
  +Subdir : string
  +TopdirRoot : RaiPath
  +SubdirRoot : RaiPath
  +GetSplit(convention : PathConventionType, itemId : string = null)
  +ApplyPathConvention()
}

class RaiFile {
  +Cloud : bool
  +Name : string
  +Ext : string
  +Path : string
  +NameWithExtension : string
  +FullName : string
  +DirList : string[]
  +Exists() : bool
  +rm() : int
  +mv(from : RaiFile, replace : bool, keepBackup : bool) : int
  +cp(from : RaiFile) : int
  +mkdir()
  +rmdir(depth : int, deleteFiles : bool)
  +backup(copy : bool) : string
  ~GetBackupRelativeDirectoryPath(sourceDirectoryPath : string) : RaiPath
}

abstract class "ConfigFile<TData>" as ConfigFile {
  +Data : TData
  +Load() : TData
}

class Os {
  +UserHomeDir : RaiPath
  +AppRootDir : RaiPath
  +TempDir : RaiPath
  +LocalBackupDir : RaiPath
  +CloudStorageRootDir : RaiPath
}

class TextFile {
  +Changed : bool
  +Lines : List~string~
  +this[i : int] : string
  +Read() : List~string~
  +Save(backup : bool)
  +Append(line : string)
  +Insert(beforeLine : int, line : string)
  +Delete(line : int)
  +Sort(reverse : bool)
}

class CsvFile {
  +Read(externalFieldNames : string, replaceBlanks : bool) : int
  +FieldNames() : string[]
  +Objects() : List~JObject~
  +Object(idx : int) : JObject
  +ToJsonFile(destFileName : string)
}

class TmpFile {
  +create()
}

class CanonicalFile {
  +Convention : PathConventionType
  +ApplyPathConvention()
  +CanonicalFile(fullName : string, defaultExt : string = "json")
}

class ImageFile {
  +NoImageNumber : int
  +ItemId : string
  +NameExt : string
  +ImageNumber : int
  +TileTemplate : string
  +TileNumber : string
  +Color : ColorInfo
  +ShortName : string
  +SetImageNumber(s : string)
  +ExtendToFirstExistingFile(extensions : string, colorInfo : ColorInfo) : bool
}

class ImageTreeFile {
  +Convention : PathConventionType
  +ApplyPathConvention()
  +Topdir : string
  +Subdir : string
  +TopdirRoot : string
  +SubdirRoot : string
  +ItemId : string
  +Path : string
  +CopyTo(destDirs : string[]) : bool
}

note right of CanonicalFile
  Canonical-by-name convention:
  file is stored in folder named like the file stem.
  Example: /Root/AfricaStage.pit -> /Root/AfricaStage/AfricaStage.pit
  Convention is enforced in constructor.
end note

note right of CanonicalPath
  Deprecated legacy type.
  Prefer direct RaiPath composition.
end note

note right of ImageTreeFile
  Tree-by-ItemId convention:
  path segments derived from ItemId prefixes
  using PathConventionType.
  3x3 => Topdir first 3, Subdir first 6 (cumulative)
  8x2 => Topdir first 8, Subdir first 10 (cumulative)
  Convention is enforced via ItemId/Path setters.
end note

CanonicalFile ..> TmpFile : uses
CanonicalFile ..> RaiPath : uses
CanonicalFile ..> CanonicalPath : uses
CanonicalFile ..|> IPathConvention
ImageTreeFile ..|> IPathConvention
ItemTreePath ..|> IPathConvention
ImageTreeFile ..> ItemTreePath : uses
ConfigFile ..> RaiPath : stores paths

RaiPath <|-- CanonicalPath
RaiPath <|-- ItemTreePath

RaiFile <|-- TextFile
TextFile <|-- CsvFile
RaiFile <|-- TmpFile
RaiFile <|-- CanonicalFile
RaiFile <|-- ConfigFile
RaiFile <|-- ImageFile
ImageFile <|-- ImageTreeFile

@enduml
