@startuml OsLib-RaiFile-Hierarchy
' Release: 3.6.1

skinparam classAttributeIconSize 0
show fields
show methods

title OsLib RaiFile Hierarchy

interface IPathConventionFile {
  +ConventionName : PathConventionType
  +ApplyPathConvention()
}

enum PathConventionType {
  CanonicalByName
  ItemIdTree
}

class RaiPath {
  +Path : string
  +operator /(self : RaiPath, subDir : string) : RaiPath
}

class "CanonicalPath\n<<deprecated>>" as CanonicalPath {
  +RootPath : string
  +FileStem : string
  +Apply()
}

class ItemTreePath {
  +RootPath : string
  +ItemId : string
  +Topdir : string
  +Subdir : string
  +Apply()
}

class RaiFile {
  +Cloud : bool
  +Name : string
  +Ext : string
  +Path : string
  +NameWithExtension : string
  +FullName : string
  +DirList : string[]
  +Exists() : bool
  +rm() : int
  +mv(from : RaiFile, replace : bool, keepBackup : bool) : int
  +cp(from : RaiFile) : int
  +mkdir()
  +rmdir(depth : int, deleteFiles : bool)
  +backup(copy : bool) : string
  ~GetBackupRelativeDirectoryPath(sourceDirectoryPath : string) : RaiPath
}

abstract class "ConfigFile<TData>" as ConfigFile {
  +Data : TData
  +Load() : TData
}

class CloudModel {
  +DropboxRoot : RaiPath
  +OneDriveRoot : RaiPath
  +GoogleDriveRoot : RaiPath
  +GetRoot(provider : CloudStorageType) : RaiPath
}

class OsConfigModel {
  +HomeDir : RaiPath
  +TempDir : RaiPath
  +LocalBackupDir : RaiPath
  +DefaultCloudOrder : List~CloudStorageType~
  +Cloud : CloudModel
  +GetCloudDirPath(provider : CloudStorageType) : RaiPath
}

class Os {
  +UserHomeDir : RaiPath
  +AppRootDir : RaiPath
  +TempDir : RaiPath
  +LocalBackupDir : RaiPath
  +CloudStorageRootDir : RaiPath
}

class OsConfigFile {
  +Persist()
}

class TextFile {
  +Changed : bool
  +Lines : List~string~
  +this[i : int] : string
  +Read() : List~string~
  +Save(backup : bool)
  +Append(line : string)
  +Insert(beforeLine : int, line : string)
  +Delete(line : int)
  +Sort(reverse : bool)
}

class CsvFile {
  +Read(externalFieldNames : string, replaceBlanks : bool) : int
  +FieldNames() : string[]
  +Objects() : List~JObject~
  +Object(idx : int) : JObject
  +ToJsonFile(destFileName : string)
}

class TmpFile {
  +create()
}

class CanonicalFile {
  +ConventionName : PathConventionType
  +ApplyPathConvention()
  +CanonicalFile(fullName : string, defaultExt : string = "json")
}

class ImageFile {
  +NoImageNumber : int
  +ItemId : string
  +NameExt : string
  +ImageNumber : int
  +TileTemplate : string
  +TileNumber : string
  +Color : ColorInfo
  +ShortName : string
  +SetImageNumber(s : string)
  +ExtendToFirstExistingFile(extensions : string, colorInfo : ColorInfo) : bool
}

class ImageTreeFile {
  +ConventionName : PathConventionType
  +ApplyPathConvention()
  +Topdir : string
  +Subdir : string
  +TopdirRoot : string
  +SubdirRoot : string
  +ItemId : string
  +Path : string
  +CopyTo(destDirs : string[]) : bool
}

note right of CanonicalFile
  Canonical-by-name convention:
  file is stored in folder named like the file stem.
  Example: /Root/AfricaStage.pit -> /Root/AfricaStage/AfricaStage.pit
  Convention is enforced in constructor.
end note

note right of CanonicalPath
  Deprecated legacy type.
  Prefer direct RaiPath composition.
end note

note right of ImageTreeFile
  Tree-by-ItemId convention:
  path segments derived from ItemId prefixes
  (Topdir: first 3, Subdir: first 6).
  Convention is enforced via ItemId/Path setters.
end note

note right of OsConfigFile
  Reusable typed JSON config file built on RaiFile.
  OsLib uses it for Os.Config and osconfig.json.
end note

CanonicalFile ..> TmpFile : uses
CanonicalFile ..> RaiPath : uses
CanonicalFile ..> CanonicalPath : uses
CanonicalFile ..|> IPathConventionFile
ImageTreeFile ..|> IPathConventionFile
ImageTreeFile ..> ItemTreePath : uses
ConfigFile ..> RaiPath : stores paths
OsConfigModel --> CloudModel : contains

RaiPath <|-- CanonicalPath
RaiPath <|-- ItemTreePath

RaiFile <|-- TextFile
TextFile <|-- CsvFile
RaiFile <|-- TmpFile
RaiFile <|-- CanonicalFile
RaiFile <|-- ConfigFile
ConfigFile <|-- OsConfigFile
RaiFile <|-- ImageFile
ImageFile <|-- ImageTreeFile

@enduml
